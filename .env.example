# Server
PORT=3000
HOST=0.0.0.0

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
CONTENT_ORIGIN=http://localhost:3000

# Data directory (git repos, worktrees, SQLite DB)
