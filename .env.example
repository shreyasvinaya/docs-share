# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
CONTENT_ORIGIN=http://localhost:3000
HOOK_BASE_URL=http://localhost:3000
WEB_DIST_DIR=
ALLOW_INSECURE_APP_URL=false

# Data directory (git repos, worktrees, SQLite DB)
DATA_DIR=./data

# Development-only login
# Set this to true only for local development. It is ignored in production.
ENABLE_DEV_LOGIN=true

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Encrypts per-user GitHub tokens saved from Settings.
GITHUB_TOKEN_SECRET=change-this-to-a-different-random-string

# Optional notifications. Email uses Resend when EMAIL_FROM and RESEND_API_KEY are set.
EMAIL_FROM=
RESEND_API_KEY=
# Slack uses an incoming webhook URL when set.
SLACK_WEBHOOK_URL=

# Background scheduler.
# Set SCHEDULER_ENABLED=false to disable all background jobs. Set an individual
# interval to 0 to disable just that job. Intervals are in milliseconds.
SCHEDULER_ENABLED=true
# Expired-share cleanup sweep (default: 15 minutes).
EXPIRED_SHARE_SWEEP_INTERVAL_MS=900000
# Failed GitHub sync retry (default: 10 minutes).
GITHUB_SYNC_RETRY_INTERVAL_MS=600000
# Max failed syncs retried per pass.
GITHUB_SYNC_RETRY_BATCH=5

# Security
# Production secrets must be non-default values with at least 32 characters.
SESSION_SECRET=change-this-to-a-random-string
DRAFT_CONTENT_SECRET=change-this-to-a-different-random-string
HOOK_SECRET=change-this-to-a-random-string
