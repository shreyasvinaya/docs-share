# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
CONTENT_ORIGIN=http://localhost:3000
HOOK_BASE_URL=http://localhost:3000
WEB_DIST_DIR=
ALLOW_INSECURE_APP_URL=false

# Deployment branding and admins
DEPLOYMENT_NAME=Docs Share
# Comma-separated admin emails for setup access (set to addresses on a domain you control)
SYSADMIN_EMAILS=

# Data directory (git repos, worktrees, SQLite DB)
DATA_DIR=./data

# Development-only login
# Set this to true only for local development. It is ignored in production.
ENABLE_DEV_LOGIN=true

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Legacy fallback for encrypted per-user GitHub tokens.
GITHUB_TOKEN_SECRET=change-this-to-a-different-random-string

# GitHub App integration for selected-repository imports.
# Create a GitHub App with read-only Contents permission and set its callback URL to:
# http://localhost:3000/api/users/me/github-app/callback
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
# OAuth credentials required to securely connect a GitHub App installation.
# These verify that the user actually owns the installation they are binding.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Optional notifications. Email uses Resend when EMAIL_FROM and RESEND_API_KEY are set.
EMAIL_FROM=
RESEND_API_KEY=
# Slack uses an incoming webhook URL when set.
SLACK_WEBHOOK_URL=

# Rate limiting (in-memory fixed window, keyed by IP / API token).
# Set RATE_LIMIT_ENABLED=false if your reverse proxy already enforces limits.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_AUTH_MAX=20
# Hard cap on distinct in-memory rate-limit buckets (eviction beyond this).
RATE_LIMIT_MAX_ENTRIES=10000

# Trust a reverse proxy to report the real client IP via X-Real-IP. Enable
# (TRUST_PROXY=true) ONLY behind a proxy that OVERWRITES X-Real-IP with the
# real socket address (e.g. nginx `proxy_set_header X-Real-IP $remote_addr;`).
# When false, forwarded headers are ignored and the socket peer address is used.
TRUST_PROXY=false

# Background scheduler.
# Set SCHEDULER_ENABLED=false to disable all background jobs. Set an individual
# interval to 0 to disable just that job. Intervals are in milliseconds.
SCHEDULER_ENABLED=true
# Expired-share cleanup sweep (default: 15 minutes).
EXPIRED_SHARE_SWEEP_INTERVAL_MS=900000
# Failed GitHub sync retry (default: 10 minutes).
GITHUB_SYNC_RETRY_INTERVAL_MS=600000
# Max failed syncs retried per pass.
GITHUB_SYNC_RETRY_BATCH=5

# Security
# Production secrets must be non-default values with at least 32 characters.
SESSION_SECRET=change-this-to-a-random-string
DRAFT_CONTENT_SECRET=change-this-to-a-different-random-string
HOOK_SECRET=change-this-to-a-random-string
