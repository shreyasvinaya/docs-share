# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
CONTENT_ORIGIN=http://localhost:3000
HOOK_BASE_URL=http://localhost:3000
WEB_DIST_DIR=
ALLOW_INSECURE_APP_URL=false

# Deployment branding and admins
DEPLOYMENT_NAME=Docs Share
SYSADMIN_EMAILS=abc@gmail.com

# Data directory (git repos, worktrees, SQLite DB)
DATA_DIR=./data

# Development-only login
# Set this to true only for local development. It is ignored in production.
ENABLE_DEV_LOGIN=true

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Legacy fallback for encrypted per-user GitHub tokens.
GITHUB_TOKEN_SECRET=change-this-to-a-different-random-string

# GitHub App integration for selected-repository imports.
# Create a GitHub App with read-only Contents permission and set its callback URL to:
# http://localhost:3000/api/users/me/github-app/callback
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=

# Optional notifications. Email uses Resend when EMAIL_FROM and RESEND_API_KEY are set.
EMAIL_FROM=
RESEND_API_KEY=
# Slack uses an incoming webhook URL when set.
SLACK_WEBHOOK_URL=

# Security
# Production secrets must be non-default values with at least 32 characters.
SESSION_SECRET=change-this-to-a-random-string
DRAFT_CONTENT_SECRET=change-this-to-a-different-random-string
HOOK_SECRET=change-this-to-a-random-string
