NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Public URLs. Use https:// unless you are running a local-only test with
# ALLOW_INSECURE_APP_URL=true.
APP_URL=https://patra.example.com
API_URL=https://patra.example.com
CONTENT_ORIGIN=https://content.patra.example.com
DEPLOYMENT_NAME="Patra"
SYSADMIN_EMAILS=admin@example.com

# Internal callback used by generated Git post-receive hooks.
HOOK_BASE_URL=http://127.0.0.1:3000

# Container defaults.
DATA_DIR=/data
WEB_DIST_DIR=/app/packages/web/dist
ALLOW_INSECURE_APP_URL=false
ENABLE_DEV_LOGIN=false

# Google OAuth.
GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=https://patra.example.com/api/auth/google/callback

# Optional integrations.
GITHUB_TOKEN_SECRET=replace-with-32-plus-random-characters
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY=
# OAuth credentials required to securely connect a GitHub App installation.
# These verify that the user actually owns the installation they are binding.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
EMAIL_FROM="Patra <notifications@patra.example.com>"
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# Rate limiting (in-memory fixed window). Set RATE_LIMIT_ENABLED=false when a
# shared limiter at the reverse proxy already covers these endpoints.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_AUTH_MAX=20
# Hard cap on distinct in-memory rate-limit buckets (eviction beyond this).
RATE_LIMIT_MAX_ENTRIES=10000

# Trust the reverse proxy to report the real client IP via X-Real-IP. Set true
# ONLY behind a proxy that OVERWRITES X-Real-IP from the real socket address
# (nginx: `proxy_set_header X-Real-IP $remote_addr;`) and does NOT pass through
# any client-supplied X-Real-IP / X-Forwarded-For. See docs/self-hosting.md.
TRUST_PROXY=true

# Background scheduler (milliseconds). Set SCHEDULER_ENABLED=false to disable
# all jobs, or set an interval to 0 to disable that job.
SCHEDULER_ENABLED=true
EXPIRED_SHARE_SWEEP_INTERVAL_MS=900000
GITHUB_SYNC_RETRY_INTERVAL_MS=600000
GITHUB_SYNC_RETRY_BATCH=5

# Generate all with at least 32 random characters. Use distinct values.
SESSION_SECRET=replace-with-32-plus-random-characters
DRAFT_CONTENT_SECRET=replace-with-32-plus-random-characters
HOOK_SECRET=replace-with-32-plus-random-characters
