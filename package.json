{
  "name": "docs-share",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "dev:server": "turbo dev --filter=@docs-share/server",
    "dev:web": "turbo dev --filter=@docs-share/web",
    "build:shared": "turbo build --filter=@docs-share/shared"
  },
  "packageManager": "bun@1.3.8",
  "overrides": {
    "esbuild": "^0.25.12"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.8"
  }
}
